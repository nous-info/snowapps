        <active>true</active>
        <admin_overrides>true</admin_overrides>
        <advanced>true</advanced>
        <applies_to/>
        <condition/>
        <controlled_by_refs/>
        <decision_type>allow</decision_type>
        <description>Certificate managers have full update access, owners can only update their own certificates</description>
        <local_or_existing>Local</local_or_existing>
        <name>Certificate Update Access</name>
        <operation display_value="write">write</operation>
        <script><![CDATA[
    // Certificate managers have full update access
    if (gs.hasRole('x_1055524_azure_ce.certificate_manager')) {
      answer = true;
    }
    // Certificate owners can only update their own certificates
    else if (gs.hasRole('x_1055524_azure_ce.certificate_owner')) {
      answer = (current.certificate_owner == gs.getUserID() || 
               current.application_owner == gs.getUserID());
    }
    else {
      answer = false;
    }
  ]]></script>
